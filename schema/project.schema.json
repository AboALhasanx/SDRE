{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/sdre/project.schema.json",
  "title": "Structured Document Rendering Engine (SDRE) Project File",
  "type": "object",
  "additionalProperties": false,
  "required": ["project"],
  "properties": {
    "project": { "$ref": "#/$defs/Project" }
  },
  "$defs": {
    "Identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "BCP47": {
      "type": "string",
      "minLength": 2,
      "maxLength": 35,
      "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"
    },
    "ColorHex": {
      "type": "string",
      "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{8})$"
    },
    "DateTime": { "type": "string", "format": "date-time" },
    "Project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meta", "theme", "subjects"],
      "properties": {
        "meta": { "$ref": "#/$defs/Meta" },
        "theme": { "$ref": "#/$defs/Theme" },
        "subjects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Subject" }
        }
      }
    },
    "Meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "author", "language", "direction"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "title": { "type": "string", "minLength": 1, "maxLength": 256 },
        "subtitle": { "type": "string", "minLength": 1, "maxLength": 256 },
        "author": { "type": "string", "minLength": 1, "maxLength": 256 },
        "language": { "$ref": "#/$defs/BCP47" },
        "direction": { "type": "string", "enum": ["ltr", "rtl"] },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "created_at": { "$ref": "#/$defs/DateTime" },
        "updated_at": { "$ref": "#/$defs/DateTime" }
      }
    },
    "Theme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page", "fonts", "colors"],
      "properties": {
        "page": { "$ref": "#/$defs/ThemePage" },
        "fonts": { "$ref": "#/$defs/ThemeFonts" },
        "text": { "$ref": "#/$defs/ThemeText" },
        "colors": { "$ref": "#/$defs/ThemeColors" },
        "headings": { "$ref": "#/$defs/ThemeHeadings" },
        "code": { "$ref": "#/$defs/ThemeCode" },
        "tables": { "$ref": "#/$defs/ThemeTables" },
        "ltr_inline_style": { "$ref": "#/$defs/ThemeLtrInlineStyle" }
      }
    },
    "Subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "blocks"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "title": { "type": "string", "minLength": 1, "maxLength": 256 },
        "description": { "type": "string", "maxLength": 4096 },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Block" }
        }
      }
    },
    "InlineNode": {
      "oneOf": [
        { "$ref": "#/$defs/InlineText" },
        { "$ref": "#/$defs/InlineCode" },
        { "$ref": "#/$defs/InlineMath" },
        { "$ref": "#/$defs/InlineLtr" }
      ]
    },
    "InlineText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "text" },
        "value": { "type": "string" }
      }
    },
    "InlineCode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "inline_code" },
        "value": { "type": "string" },
        "lang": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    },
    "InlineMath": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "inline_math" },
        "value": { "type": "string", "minLength": 1, "maxLength": 8192 }
      }
    },
    "InlineLtr": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "ltr" },
        "value": { "type": "string", "minLength": 1, "maxLength": 256 },
        "style": { "type": "string", "enum": ["plain", "boxed", "mono"] }
      }
    },
    "Block": {
      "oneOf": [
        { "$ref": "#/$defs/BlockSection" },
        { "$ref": "#/$defs/BlockParagraph" },
        { "$ref": "#/$defs/BlockSubsection" },
        { "$ref": "#/$defs/BlockCodeBlock" },
        { "$ref": "#/$defs/BlockMathBlock" },
        { "$ref": "#/$defs/BlockTable" },
        { "$ref": "#/$defs/BlockImage" },
        { "$ref": "#/$defs/BlockImagePlaceholder" },
        { "$ref": "#/$defs/BlockNote" },
        { "$ref": "#/$defs/BlockWarning" },
        { "$ref": "#/$defs/BlockBulletList" },
        { "$ref": "#/$defs/BlockNumberedList" },
        { "$ref": "#/$defs/BlockHorizontalRule" },
        { "$ref": "#/$defs/BlockPageBreak" }
      ]
    },
    "BlockSection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "section" },
        "title": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "BlockSubsection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "subsection" },
        "title": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "BlockParagraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "content"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "paragraph" },
        "content": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/InlineNode" }
        }
      }
    },
    "BlockCodeBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "value"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "code_block" },
        "value": { "type": "string" },
        "lang": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    },
    "BlockMathBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "value"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "math_block" },
        "value": { "type": "string", "minLength": 1, "maxLength": 65535 }
      }
    },
    "TableCell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": {
        "content": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/InlineNode" }
        }
      }
    },
    "BlockTable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "rows"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "table" },
        "caption": { "type": "array", "items": { "$ref": "#/$defs/InlineNode" } },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/TableCell" }
          }
        }
      }
    },
    "BlockImage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "src"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "image" },
        "src": { "type": "string", "minLength": 1, "format": "uri-reference" },
        "alt": { "type": "string", "maxLength": 1024 },
        "caption": { "type": "array", "items": { "$ref": "#/$defs/InlineNode" } }
      }
    },
    "BlockImagePlaceholder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "anyOf": [{ "required": ["reserve_height_mm"] }, { "required": ["aspect_ratio"] }],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "image_placeholder" },
        "caption": { "type": "array", "items": { "$ref": "#/$defs/InlineNode" } },
        "reserve_height_mm": { "type": "number", "exclusiveMinimum": 0, "maximum": 1000 },
        "aspect_ratio": { "type": "number", "exclusiveMinimum": 0, "maximum": 100 },
        "border": { "type": "boolean" },
        "label": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "BlockNote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "content"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "note" },
        "content": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/InlineNode" } }
      }
    },
    "BlockWarning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "content"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "warning" },
        "content": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/InlineNode" } }
      }
    },
    "InlineItem": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/InlineNode" }
    },
    "BlockBulletList": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "items"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "bullet_list" },
        "items": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/InlineItem" } }
      }
    },
    "BlockNumberedList": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "items"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "numbered_list" },
        "items": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/InlineItem" } }
      }
    },
    "BlockHorizontalRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "horizontal_rule" }
      }
    },
    "BlockPageBreak": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type"],
      "properties": {
        "id": { "$ref": "#/$defs/Identifier" },
        "type": { "const": "page_break" }
      }
    },
    "ThemePage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["size", "dpi", "margin_mm"],
      "properties": {
        "size": { "type": "string", "enum": ["A4", "Letter"] },
        "dpi": { "type": "integer", "minimum": 72, "maximum": 1200 },
        "margin_mm": {
          "type": "object",
          "additionalProperties": false,
          "required": ["top", "right", "bottom", "left"],
          "properties": {
            "top": { "type": "number", "minimum": 0, "maximum": 100 },
            "right": { "type": "number", "minimum": 0, "maximum": 100 },
            "bottom": { "type": "number", "minimum": 0, "maximum": 100 },
            "left": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        }
      }
    },
    "ThemeFonts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "mono"],
      "properties": {
        "base": { "type": "string", "minLength": 1, "maxLength": 128 },
        "mono": { "type": "string", "minLength": 1, "maxLength": 128 },
        "math": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "ThemeText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_size_px", "line_height"],
      "properties": {
        "base_size_px": { "type": "number", "minimum": 6, "maximum": 72 },
        "line_height": { "type": "number", "minimum": 1.0, "maximum": 3.0 }
      }
    },
    "ThemeColors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "background", "muted", "accent", "border", "code_bg"],
      "properties": {
        "text": { "$ref": "#/$defs/ColorHex" },
        "background": { "$ref": "#/$defs/ColorHex" },
        "muted": { "$ref": "#/$defs/ColorHex" },
        "accent": { "$ref": "#/$defs/ColorHex" },
        "border": { "$ref": "#/$defs/ColorHex" },
        "code_bg": { "$ref": "#/$defs/ColorHex" }
      }
    },
    "ThemeHeadings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "h1_size_px": { "type": "number", "minimum": 6, "maximum": 200 },
        "h2_size_px": { "type": "number", "minimum": 6, "maximum": 200 },
        "h3_size_px": { "type": "number", "minimum": 6, "maximum": 200 },
        "h4_size_px": { "type": "number", "minimum": 6, "maximum": 200 }
      }
    },
    "ThemeCode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "font_size_px": { "type": "number", "minimum": 6, "maximum": 72 },
        "background": { "$ref": "#/$defs/ColorHex" }
      }
    },
    "ThemeTables": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "border_color": { "$ref": "#/$defs/ColorHex" },
        "header_background": { "$ref": "#/$defs/ColorHex" }
      }
    },
    "ThemeLtrInlineStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "boxed_border_color": { "$ref": "#/$defs/ColorHex" },
        "boxed_background": { "$ref": "#/$defs/ColorHex" },
        "mono_background": { "$ref": "#/$defs/ColorHex" }
      }
    }
  }
}
