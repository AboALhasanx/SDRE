            "value": "a^2 + b^2 = c^2"
          },
          {
            "id": "code_binary_search",
            "type": "code_block",
            "lang": "cpp",
            "value": "int binarySearch(int arr[], int n, int x) {\n    int low = 0;\n    int high = n - 1;\n\n    while (low <= high) {\n        int mid = (low + high) / 2;\n\n        if (arr[mid] == x) return mid;\n        if (x < arr[mid]) high = mid - 1;\n        else low = mid + 1;\n    }\n\n    return -1;\n}"
          },
          {
