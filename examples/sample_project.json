              { "type": "inline_math", "value": "O(log n)" },
              { "type": "text", "value": "." }
            ]
          },
          {
            "id": "code_1",
            "type": "code_block",
            "lang": "python",
            "value": "def binary_search(a, x):\n    lo, hi = 0, len(a) - 1\n    while lo <= hi:\n        mid = (lo + hi) // 2\n        if a[mid] == x:\n            return mid\n        if a[mid] < x:\n            lo = mid + 1\n        else:\n            hi = mid - 1\n    return -1\n"
          },
