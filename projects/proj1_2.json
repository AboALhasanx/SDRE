            "content": [
              {
                "type": "text",
                "value": "يهدف هذا النظام إلى بناء مستندات تقنية عربية بطريقة منظمة. تعتمد بعض الخوارزميات مثل"
              },
              {
                "type": "ltr",
                "value": "Binary Search",
                "style": "boxed"
              },
              {
                "type": "text",
                "value": "على بيانات مرتبة، ويكون التعقيد الزمني تقريبًا"
              },
              {
                "type": "inline_math",
                "value": "O(log n)"
              },
              {
                "type": "text",
                "value": "، ويمكن تمثيل الشرط البرمجي المختصر بالشكل"
              },
              {
                "type": "inline_code",
                "value": "if (x < y)",
                "lang": "cpp"
              },
              {
                "type": "text",
                "value": "."
              }
            ]
          },
          {
            "id": "math_block_1",
            "type": "math_block",
            "value": "a^2 + b^2 = c^2"
          },
          {
            "id": "code_block_1",
            "type": "code_block",
            "value": "int binarySearch(int arr[], int n, int x) {\n    int low = 0;\n    int high = n - 1;\n\n    while (low <= high) {\n        int mid = (low + high) / 2;\n\n        if (arr[mid] == x) return mid;\n        if (x < arr[mid]) high = mid - 1;\n        else low = mid + 1;\n    }\n\n    return -1;\n}",
            "lang": "cpp"
          },
          {
            "id": "note_1",
            "type": "note",
            "content": [
              {
                "type": "text",
                "value": "يجب أن تكون البيانات مرتبة مسبقًا قبل تطبيق"
              },
              {
                "type": "ltr",
                "value": "Binary Search",
                "style": "plain"
              },
              {
                "type": "text",
                "value": "وإلا ستكون النتيجة غير صحيحة."
              }
